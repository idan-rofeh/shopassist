{
    "name": "@chatbot/catalog",
    "version": "0.0.1",
    "private": true,
    "main": "./dist/index.js",
    "scripts": {
        "prebuild": "npm run build --workspace @chatbot/shared && npm run build --workspace @chatbot/server-utils",
        "build": "tsc -p tsconfig.json",
        "predev": "npm run build --workspace @chatbot/shared && npm run build --workspace @chatbot/server-utils",
        "dev": "tsx watch src/index.ts",
        "prestart": "npm run build --workspace @chatbot/shared && npm run build --workspace @chatbot/server-utils",
        "start": "node dist/index.js",
        "clean": "rm -rf dist",
        "test": "jest"
    },
    "dependencies": {
        "@chatbot/server-utils": "^0.0.1",
        "@chatbot/shared": "*",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "mongodb": "^7.5.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jest": "^30.0.0",
        "@types/node": "^22.13.10",
        "@types/supertest": "^7.2.0",
        "jest": "^30.4.2",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.11",
        "tsx": "^4.19.3",
        "typescript": "~6.0.2"
    }
}
