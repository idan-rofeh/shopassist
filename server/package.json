{
  "name": "@chatbot/server",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "prebuild": "npm run build --workspace @chatbot/shared",
    "build": "tsc -p tsconfig.json",
    "predev": "npm run build --workspace @chatbot/shared",
    "dev": "tsx watch src/index.ts",
    "prestart": "npm run build --workspace @chatbot/shared",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@chatbot/shared": "*",
    "@google/generative-ai": "^0.24.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "~6.0.2"
  }
}
